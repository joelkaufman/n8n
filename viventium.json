    {
      "parameters": {
        "jsCode": "function cleanDate(value = \"\") {\n    if (value == \"\") {\n        return \"\";\n    }\n    return new Date(value.replace(\"12:00:00 AM\", \"\").trim()).toISOString().split('T')[0];\n}\n\n\nconst chunkArray = (arr, size) => \n  Array.from({ length: Math.ceil(arr.length / size) }, (v, i) =>\n    arr.slice(i * size, i * size + size)\n  );\n\nlet data = await Promise.all($input.all().map(async function(o){\n      console.log(o)\n      return {\n        Last_Name:o.json['Last Name'],\n        First_Name:o.json['First Name'],\n        DOB:cleanDate(o.json['Birth Date']),\n        SSN:o.json['Social Security Number'].replaceAll('-',''),\n        Address_1:o.json['Primary Address 1'],\n        City:o.json['Primary City'],\n        State:o.json['Primary State'],\n        Zip:o.json['Primary Zip Code'],\n        Hire_Date:cleanDate(o.json['Hire Date']),\n        Rate:Math.round((o.json['BaseRate'] || 0) * 100) / 100\n      }\n    }))\n\nreturn chunkArray(data,100).map(o=>{\n  return {\n    json:{\n      data:o\n    }\n  }\n})\n\n\n"
      },
